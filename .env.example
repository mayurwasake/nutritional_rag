DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=postgres

# Using a local embedding model that fits memory easily, 
# for text-embedding-3-small you would use 1536 dim and an OpenAI package
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIM=384
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
GEMINI_API_KEY=
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# LangSmith Observability & Tracing Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nutritional_rag_tracker